{
  "name": "mcp-for-flarum",
  "version": "0.5.1",
  "description": "Model Context Protocol server for Flarum. Gives AI agents full access to any Flarum forum's API: discussions, posts, users, tags, groups, moderation, settings, and third-party extension endpoints.",
  "keywords": [
    "flarum",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "forum"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "linkrobins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linkrobins/mcp-for-flarum.git"
  },
  "type": "module",
  "bin": {
    "mcp-for-flarum": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
